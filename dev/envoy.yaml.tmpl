# Envoy deployment for local Rutoso development.
# Placeholders are substituted by 'make dev-up' using sed:
#   __HOST_IP__        → gateway IP of the Docker 'kind' network (host machine)
#   __ENVOY_IMAGE__    → Envoy Docker image tag
#   __ENVOY_NODE_ID__  → node.id sent to the xDS server (Rutoso)
#   __KIND_NAMESPACE__ → Kubernetes namespace
---
# Bootstrap config: tells Envoy where to connect for xDS.
# All listeners, clusters and routes come dynamically from Rutoso.
apiVersion: v1
kind: ConfigMap
metadata:
  name: envoy-bootstrap
  namespace: __KIND_NAMESPACE__
data:
  envoy.yaml: |
    node:
      id: "__ENVOY_NODE_ID__"
      cluster: "rutoso-dev"

    dynamic_resources:
      ads_config:
        api_type: GRPC
        transport_api_version: V3
        grpc_services:
          - envoy_grpc:
              cluster_name: xds_cluster
      lds_config:
        resource_api_version: V3
        ads: {}
      cds_config:
        resource_api_version: V3
        ads: {}

    static_resources:
      clusters:
        - name: xds_cluster
          connect_timeout: 5s
          type: STRICT_DNS
          lb_policy: ROUND_ROBIN
          # Force HTTP/2 for gRPC
          typed_extension_protocol_options:
            envoy.extensions.upstreams.http.v3.HttpProtocolOptions:
              "@type": type.googleapis.com/envoy.extensions.upstreams.http.v3.HttpProtocolOptions
              explicit_http_config:
                http2_protocol_options: {}
          load_assignment:
            cluster_name: xds_cluster
            endpoints:
              - lb_endpoints:
                  - endpoint:
                      address:
                        socket_address:
                          address: __HOST_IP__
                          port_value: 18000

    admin:
      address:
        socket_address:
          address: 0.0.0.0
          port_value: 9901

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: envoy
  namespace: __KIND_NAMESPACE__
  labels:
    app: envoy
spec:
  replicas: 1
  selector:
    matchLabels:
      app: envoy
  template:
    metadata:
      labels:
        app: envoy
    spec:
      containers:
        - name: envoy
          image: __ENVOY_IMAGE__
          args:
            - "-c"
            - "/etc/envoy/envoy.yaml"
            - "--log-level"
            - "info"
          ports:
            - name: http
              containerPort: 10000
            - name: admin
              containerPort: 9901
          volumeMounts:
            - name: config
              mountPath: /etc/envoy
          readinessProbe:
            httpGet:
              path: /ready
              port: 9901
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /server_info
              port: 9901
            initialDelaySeconds: 10
            periodSeconds: 10
      volumes:
        - name: config
          configMap:
            name: envoy-bootstrap

---
# ClusterIP for internal access and port-forward
apiVersion: v1
kind: Service
metadata:
  name: envoy-admin
  namespace: __KIND_NAMESPACE__
spec:
  selector:
    app: envoy
  ports:
    - name: admin
      port: 9901
      targetPort: 9901

---
# NodePort — accessible from the host via the extraPortMappings in kind-cluster.yaml
apiVersion: v1
kind: Service
metadata:
  name: envoy
  namespace: __KIND_NAMESPACE__
spec:
  selector:
    app: envoy
  type: NodePort
  ports:
    - name: http
      port: 10000
      targetPort: 10000
      nodePort: 30000
    - name: admin
      port: 9901
      targetPort: 9901
      nodePort: 30901
